// ── STORAGE
const STORAGE_KEY = "conum_links_v1";
function loadLinks() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}"); } catch { return {}; }
}
function saveLink(num, driveId) {
  const links = loadLinks();
  if (driveId) links[num] = driveId; else delete links[num];
  localStorage.setItem(STORAGE_KEY, JSON.stringify(links));
}
function getLink(num) { return loadLinks()[num] || ""; }

// ── EXPORT / IMPORT JSON
function exportLinks() {
  const links = loadLinks();
  if (!Object.keys(links).length) { showToast("⚠ Aucun lien à exporter"); return; }
  const blob = new Blob([JSON.stringify(links, null, 2)], { type: "application/json" });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement("a");
  a.href     = url;
  a.download = `conum-liens-${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(url);
  showToast(`✓ ${Object.keys(links).length} liens exportés`);
}

function importLinks(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (typeof data !== "object" || Array.isArray(data)) throw new Error();
      // Validation : ne garder que les clés qui correspondent au catalogue
      const validNums = new Set(CATALOGUE.map(a => a.num));
      const merged    = loadLinks();
      let count = 0;
      for (const [k, v] of Object.entries(data)) {
        if (validNums.has(k) && typeof v === "string") { merged[k] = v; count++; }
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(merged));
      renderMain();
      showToast(`✓ ${count} liens importés`);
    } catch {
      showToast("⚠ Fichier JSON invalide");
    }
  };
  reader.readAsText(file);
}

// ── URL UTILS
function extractDriveId(url) {
  if (!url) return "";
  // Format /file/d/ID/  ou  /presentation/d/ID/  ou  /document/d/ID/
  const m = url.match(/\/(?:file|presentation|document|spreadsheets)\/d\/([a-zA-Z0-9_-]{10,})/);
  if (m) return m[1];
  // Format id=ID dans les query params
  const q = url.match(/[?&]id=([a-zA-Z0-9_-]{10,})/);
  if (q) return q[1];
  // ID brut collé directement
  if (/^[a-zA-Z0-9_-]{20,}$/.test(url.trim())) return url.trim();
  return "";
}
function driveViewUrl(id)     { return `https://drive.google.com/file/d/${id}/view`; }
function driveDownloadUrl(id) { return `https://drive.google.com/uc?export=download&id=${id}`; }

// ── STATE
let currentChap = "all";
let currentSearch = "";
let editMode = false;
let modalAtelier = null;
let editAtelier = null;

function filtered() {
  return CATALOGUE.filter(a => {
    const matchChap = currentChap === "all" || a.chap === currentChap;
    const q = currentSearch.toLowerCase();
    return matchChap && (!q || a.titre.toLowerCase().includes(q) || a.num.toLowerCase().includes(q));
  });
}

// ── RENDER
function renderMain() {
  const main = document.getElementById("main");
  const list = filtered();
  const links = loadLinks();

  const linkedCount = CATALOGUE.filter(a => links[a.num]).length;
  document.getElementById("count-badge").textContent =
    linkedCount ? `${linkedCount} / ${CATALOGUE.length} liés` : `${CATALOGUE.length} ateliers`;

  if (!list.length) {
    main.innerHTML = `<div class="empty-state"><div class="empty-icon">🔍</div>Aucun atelier trouvé.</div>`;
    return;
  }

  const grouped = {};
  list.forEach(a => { if (!grouped[a.chap]) grouped[a.chap] = []; grouped[a.chap].push(a); });

  main.innerHTML = Object.entries(grouped).map(([chap, ateliers]) => `
    <section class="chap-section">
      <div class="chap-header">
        <div class="chap-letter bg-${chap}">${chap}</div>
        <div>
          <div class="chap-name">${CHAPITRES[chap].label}</div>
          <div class="chap-sub">${ateliers.length} atelier${ateliers.length > 1 ? 's' : ''}</div>
        </div>
      </div>
      <div class="grid">
        ${ateliers.map(a => {
          const hasLink = !!links[a.num];
          return `
          <div class="card ${hasLink ? 'has-link' : ''}" tabindex="0" data-id="${a.num}" data-chap="${a.chap}">
            <div class="card-thumb thumb-${a.chap}">
              <span class="card-num">${a.num}</span>
              <span class="card-link-dot"></span>
              ${a.emoji}
            </div>
            <div class="card-body">
              <div class="card-title">${a.titre}</div>
              <div class="card-actions">
                <button class="btn btn-${a.chap}" onclick="openModal('${a.num}',event)">▶ Ouvrir</button>
                <button class="btn btn-ghost" title="Télécharger" onclick="downloadFile('${a.num}',event)">⬇</button>
                <button class="card-edit-btn" title="Modifier le lien Drive" onclick="openEditModal('${a.num}',event)">✏️</button>
              </div>
            </div>
          </div>`;
        }).join("")}
      </div>
    </section>
  `).join("");

}

// ── MODAL OUVERTURE
function openModal(num, e) {
  if (e) e.stopPropagation();
  const a = CATALOGUE.find(x => x.num === num);
  if (!a) return;
  modalAtelier = a;
  const driveId = getLink(num);

  const thumb = document.getElementById("modal-thumb");
  thumb.className = `modal-thumb thumb-${a.chap}`;
  thumb.textContent = a.emoji;
  document.getElementById("modal-eyebrow").textContent = `${a.num} · ${CHAPITRES[a.chap].label}`;
  document.getElementById("modal-title").textContent = a.titre;
  document.getElementById("modal-filename").textContent = `${a.num} — ${a.titre}.pptx`;

  const statusEl = document.getElementById("modal-drive-status");
  statusEl.innerHTML = driveId
    ? `<span style="color:#22c55e;font-size:12px;font-weight:600">● Disponible</span>`
    : `<span class="no-drive">⚠ Lien manquant</span>`;

  const openBtn = document.getElementById("modal-open");
  openBtn.className = `modal-btn btn-${a.chap}`;

  document.getElementById("modal").classList.add("open");
}

function closeModal() { document.getElementById("modal").classList.remove("open"); modalAtelier = null; }

// ── MODAL ÉDITION
function openEditModal(num, e) {
  if (e) e.stopPropagation();
  editAtelier = CATALOGUE.find(x => x.num === num);
  if (!editAtelier) return;

  document.getElementById("edit-modal-title").textContent = `${editAtelier.num} — ${editAtelier.titre}`;
  const existing = getLink(num);
  const input = document.getElementById("edit-url-input");
  input.value = existing ? driveViewUrl(existing) : "";
  updatePreview(input.value);

  document.getElementById("edit-modal").classList.add("open");
  setTimeout(() => input.focus(), 200);
}

function closeEditModal() { document.getElementById("edit-modal").classList.remove("open"); editAtelier = null; }

function updatePreview(val) {
  const preview = document.getElementById("url-preview");
  if (!val) { preview.textContent = "—"; preview.className = "url-preview"; return; }
  const id = extractDriveId(val);
  if (id) {
    preview.textContent = `ID : ${id}`;
    preview.className = "url-preview valid";
  } else {
    preview.textContent = "Lien non reconnu — vérifie le format";
    preview.className = "url-preview invalid";
  }
}

function showToast(msg = "✓ Lien enregistré") {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2200);
}

function downloadFile(num, e) {
  if (e) e.stopPropagation();
  const id = getLink(num);
  if (!id) { openEditModal(num, e); return; }
  window.open(driveDownloadUrl(id), "_blank");
}

// ── EVENTS
document.getElementById("edit-url-input").addEventListener("input", e => updatePreview(e.target.value));

document.getElementById("btn-save").addEventListener("click", () => {
  if (!editAtelier) return;
  const val = document.getElementById("edit-url-input").value.trim();
  const id = extractDriveId(val) || (val.length > 4 && !val.includes("/") ? val : "");
  if (val && !id) { alert("Lien non reconnu. Colle l'URL complète Google Drive."); return; }
  saveLink(editAtelier.num, id);
  closeEditModal();
  renderMain();
  showToast(`✓ Lien enregistré pour ${editAtelier.num}`);
});

document.getElementById("btn-clear").addEventListener("click", () => {
  if (!editAtelier) return;
  if (!confirm("Supprimer le lien pour cet atelier ?")) return;
  saveLink(editAtelier.num, "");
  closeEditModal();
  renderMain();
  showToast("✕ Lien supprimé");
});

document.getElementById("btn-cancel").addEventListener("click", closeEditModal);
document.getElementById("edit-modal-close").addEventListener("click", closeEditModal);
document.getElementById("edit-modal").addEventListener("click", e => { if (e.target === document.getElementById("edit-modal")) closeEditModal(); });

document.getElementById("modal-close").addEventListener("click", closeModal);
document.getElementById("modal").addEventListener("click", e => { if (e.target === document.getElementById("modal")) closeModal(); });

document.getElementById("modal-open").addEventListener("click", () => {
  if (!modalAtelier) return;
  const id = getLink(modalAtelier.num);
  if (!id) { closeModal(); openEditModal(modalAtelier.num); return; }
  window.open(driveViewUrl(id), "_blank");
});
document.getElementById("modal-download").addEventListener("click", () => {
  if (!modalAtelier) return;
  const id = getLink(modalAtelier.num);
  if (!id) { closeModal(); openEditModal(modalAtelier.num); return; }
  window.open(driveDownloadUrl(id), "_blank");
});

// Toggle mode édition
document.getElementById("edit-toggle").addEventListener("click", () => {
  editMode = !editMode;
  document.body.classList.toggle("edit-mode", editMode);
  const btn = document.getElementById("edit-toggle");
  btn.classList.toggle("on", editMode);
  btn.textContent = editMode ? "✅ Mode édition ON" : "✏️ Gérer les liens";
});

document.getElementById("btn-export").addEventListener("click", exportLinks);
document.getElementById("btn-import").addEventListener("click", () => document.getElementById("import-file").click());
document.getElementById("import-file").addEventListener("change", e => {
  importLinks(e.target.files[0]);
  e.target.value = ""; // reset pour permettre re-import du même fichier
});

document.querySelectorAll(".chap-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".chap-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    currentChap = btn.dataset.chap;
    renderMain();
  });
});

document.getElementById("search").addEventListener("input", e => {
  currentSearch = e.target.value;
  if (currentSearch) {
    document.querySelectorAll(".chap-btn").forEach(b => b.classList.remove("active"));
    document.querySelector('[data-chap="all"]').classList.add("active");
    currentChap = "all";
  }
  renderMain();
});

document.addEventListener("keydown", e => {
  if (e.key === "Escape") { closeModal(); closeEditModal(); }
  if (e.key === "/" && !document.getElementById("modal").classList.contains("open") && !document.getElementById("edit-modal").classList.contains("open")) {
    document.getElementById("search").focus(); e.preventDefault();
  }
});

renderMain();

// ── DÉLÉGATION UNIQUE SUR #main (évite les listeners orphelins après re-render)
document.getElementById("main").addEventListener("click", e => {
  const card = e.target.closest(".card");
  if (!card) return;
  if (!e.target.closest("button")) openModal(card.dataset.id, e);
});
document.getElementById("main").addEventListener("keydown", e => {
  if (e.key !== "Enter") return;
  const card = e.target.closest(".card");
  if (card) openModal(card.dataset.id, e);
});
</script>
